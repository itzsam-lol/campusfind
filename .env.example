# Copy to .env and fill in real values for any production deployment.

# Prisma + SQLite. The file lives at prisma/dev.db
DATABASE_URL="file:./dev.db"

# Long random string. Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-string-at-least-48-chars-please-rotate"

# Cookie name & lifetime (seconds)
SESSION_COOKIE="cf_session"
SESSION_MAX_AGE="604800"

# Allowed email domains for sign-up (comma separated, leading dot optional)
ALLOWED_EMAIL_DOMAINS="igdtuw.ac.in,iiitd.ac.in"

# Bootstrap admin emails (these accounts gain admin role on first sign-in)
ADMIN_EMAILS="admin@igdtuw.ac.in"

# OTP behaviour
OTP_TTL_SECONDS="300"
OTP_MAX_ATTEMPTS="5"

# In dev, the OTP is echoed back in the response so you can test without SMTP.
# Set to "false" (or anything other than "true") in production.
OTP_DEV_ECHO="true"

# Public origin used for cookies + redirects
NEXT_PUBLIC_APP_URL="http://localhost:3000"
